{
  "rewrites": [
    {
      "source": "/api/spotify-token",
      "destination": "/api/spotify-token.js"
    },
    {
      "source": "/api/deezer/:path*",
      "destination": "https://api.deezer.com/:path*"
    },
    {
      "source": "/api/genius/:path*",
      "destination": "https://api.genius.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
